---
/**
 * Getting-started section — trial launch with direct signup.
 * Pricing is intentionally NOT announced; no accompaniment/SLA promises.
 */
const signupUrl = 'https://app.qaydalaqar.com/auth/signup';
---

<section id="access" class="py-20 md:py-28 bg-[#0f1729] border-y border-[#1f2937]">
  <div class="container">

    <!-- Header -->
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        سجّل وابدأ مباشرة
      </h2>
      <p class="text-text-muted text-lg max-w-2xl mx-auto">
        قيد العقار في مرحلة إطلاق تجريبي — أنشئ حساب مكتبك بالبريد الإلكتروني وابدأ الاستخدام فوراً.
      </p>
    </div>

    <!-- Getting-started card -->
    <div class="max-w-2xl mx-auto p-8 md:p-10 rounded-2xl bg-[#111c32] border border-brand-primary/30 text-center">
      <ul class="space-y-4 text-sm text-gray-300 max-w-md mx-auto mb-8 text-right">
        {[
          'تسجيل مباشر بالبريد الإلكتروني — بلا موافقات ولا انتظار.',
          'تبدأ فوراً على عمل مكتبك الحقيقي: عقارات وعقود وتحصيل.',
          'ملاحظاتك في مرحلة الإطلاق التجريبي تشكّل المنتج مباشرة.',
          'الأسعار تُعلن لاحقاً — المستخدمون الحاليون يُبلَّغون بها أولاً قبل أي التزام.',
        ].map((item) => (
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#C5CCD9" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0 mt-0.5">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            {item}
          </li>
        ))}
      </ul>
      <a
        href={signupUrl}
        class="inline-block px-10 py-4 bg-brand-primary hover:bg-brand-dark text-[#0F172D] font-bold rounded-xl transition-all hover:shadow-lg hover:shadow-brand-primary/20 hover:-translate-y-0.5"
      >
        أنشئ حساب مكتبك
      </a>
      <p class="text-text-muted text-sm mt-6">
        لديك حساب؟
        <a href="https://app.qaydalaqar.com/auth/login" class="text-brand-primary hover:underline">تسجيل الدخول</a>
        · أسئلة؟
        <a href="mailto:info@qaydalaqar.com" class="text-brand-primary hover:underline">راسلنا</a>
      </p>
    </div>

  </div>
</section>
