---
/**
 * Access section — replaces the old pricing plans.
 * Pricing is intentionally NOT announced; access is via a guided pilot.
 */
const requestAccessMailto = `mailto:info@qaydalaqar.com?subject=${encodeURIComponent('طلب انضمام إلى قيد العقار')}`;
---

<section id="access" class="py-20 md:py-28 bg-[#0f1729] border-y border-[#1f2937]">
  <div class="container">

    <!-- Header -->
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        الوصول حالياً عبر تجربة موجّهة
      </h2>
      <p class="text-text-muted text-lg max-w-2xl mx-auto">
        نعمل الآن مع عدد محدود من المكاتب في تجربة موجّهة، لنضمن أن المنتج يخدم يوم المكتب الحقيقي قبل الفتح العام.
      </p>
    </div>

    <!-- Access card -->
    <div class="max-w-2xl mx-auto p-8 md:p-10 rounded-2xl bg-[#111c32] border border-brand-primary/30 text-center">
      <h3 class="text-white font-bold text-xl mb-4">ماذا تعني التجربة الموجّهة؟</h3>
      <ul class="space-y-4 text-sm text-gray-300 max-w-md mx-auto mb-8 text-right">
        {[
          'نفعّل مكتبك بنطاق متفق عليه ونرافقك في البداية.',
          'تستخدم النظام على عمل مكتبك الحقيقي، وملاحظاتك تشكّل المنتج مباشرة.',
          'قناة تواصل واحدة واضحة طوال فترة التجربة.',
          'الأسعار لم تُعلن بعد — المنضمون في التجربة يُبلَّغون بها أولاً قبل أي التزام.',
        ].map((item) => (
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#C5CCD9" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0 mt-0.5">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            {item}
          </li>
        ))}
      </ul>
      <a
        href={requestAccessMailto}
        class="inline-block px-10 py-4 bg-brand-primary hover:bg-brand-dark text-[#0F172D] font-bold rounded-xl transition-all hover:shadow-lg hover:shadow-brand-primary/20 hover:-translate-y-0.5"
      >
        راسلنا لطلب الانضمام
      </a>
      <p class="text-text-muted text-sm mt-6">
        لديك حساب؟
        <a href="https://app.qaydalaqar.com/auth/login" class="text-brand-primary hover:underline">تسجيل الدخول</a>
      </p>
    </div>

  </div>
</section>
