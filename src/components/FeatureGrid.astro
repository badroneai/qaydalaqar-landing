---
const features = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><path stroke-linecap="round" d="M12 3v4"/></svg>`,
    title: 'الرادار والمتابعات',
    desc: 'ابدأ يومك بقائمة انتباه واحدة: دفعات متأخرة، عقود تنتهي قريباً، وفجوات تشغيلية — وحوّلها بضغطة إلى متابعات لها مسؤول وحالة وسجل نشاط.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M7 3h7l4 4v14H7z"/><path stroke-linecap="round" stroke-linejoin="round" d="M14 3v4h4M10 12h5M10 16h5"/></svg>`,
    title: 'عقود الإيجار والاستحقاقات',
    desc: 'عقود بجداول استحقاق واضحة، ومستند عقد جاهز للطباعة. وعندك عقد من منصة إيجار؟ ارفع ملفه (PDF) ويُنشأ العقد وجدوله بعد مراجعتك.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><ellipse cx="12" cy="6.5" rx="6.5" ry="3"/><path d="M5.5 6.5v5c0 1.66 2.9 3 6.5 3s6.5-1.34 6.5-3v-5"/><path d="M5.5 11.5v5c0 1.66 2.9 3 6.5 3s6.5-1.34 6.5-3v-5"/></svg>`,
    title: 'التحصيل',
    desc: 'دفعات مربوطة بالاستحقاقات، تُسجَّل من داخل المتابعة نفسها، ونسبة تحصيل تراها ولا تخمّنها.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 4h11a2 2 0 0 1 2 2v14H7a2 2 0 0 1-2-2z"/><path stroke-linecap="round" d="M5 17.5A2.5 2.5 0 0 1 7.5 15H18M9 8h5"/></svg>`,
    title: 'دفتر المكتب',
    desc: 'مصروفات المكتب والتزاماته الدورية في دفتر مستقل عن حسابات العقارات، بتصنيفات وتقارير خاصة به.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" d="M4 20h16M7 20v-6M12 20V9M17 20V5"/></svg>`,
    title: 'التقارير',
    desc: 'تدفق نقدي، ونسبة تحصيل، وأعمار الديون، وملخص لكل عقار — أرقام المكتب أمامك لا في ذاكرة أحد.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4 7h16v13H4zM3 4h18v3H3zM10 11h4"/></svg>`,
    title: 'المستندات والذاكرة',
    desc: 'خطابات رسمية وأرشيف مستندات وذاكرة مكتب تُبقي المعرفة داخل المكتب لا في جوالات الموظفين.',
  },
];
---

<section id="features" class="py-20 md:py-28">
  <div class="container">

    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        وحدات المكتب في
        <span class="gradient-text"> مكان واحد</span>
      </h2>
      <p class="text-text-muted text-lg max-w-2xl mx-auto">
        مبني حول يوم المكتب العقاري السعودي الفعلي: من رادار الصباح إلى تحصيل آخر دفعة.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((feature) => (
        <div class="card-hover p-6 rounded-2xl bg-[#0f1729] border border-[#1f2937]">
          <div class="w-12 h-12 rounded-xl bg-brand-primary/10 flex items-center justify-center text-brand-primary mb-5">
            <Fragment set:html={feature.icon} />
          </div>
          <h3 class="text-white font-semibold text-lg mb-3">{feature.title}</h3>
          <p class="text-text-muted text-sm leading-relaxed">{feature.desc}</p>
        </div>
      ))}
    </div>

  </div>
</section>
