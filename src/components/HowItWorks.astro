---
const requestAccessMailto = `mailto:info@qaydalaqar.com?subject=${encodeURIComponent('طلب انضمام إلى قيد العقار')}`;

const steps = [
  {
    number: '١',
    title: 'افتح الرادار',
    desc: 'ترى فوراً الدفعات المتأخرة والعقود التي تقترب من الانتهاء والفجوات التشغيلية، مرتبة حسب الأولوية.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><path stroke-linecap="round" d="M12 3v4"/></svg>`,
  },
  {
    number: '٢',
    title: 'حوّلها إلى متابعات',
    desc: 'كل إشارة تتحول بضغطة إلى متابعة لها مسؤول وحالة وسجل نشاط — لا شيء يضيع في الجوال أو الدفاتر.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5h11M9 12h11M9 19h11M4 5h.01M4 12h.01M4 19h.01"/></svg>`,
  },
  {
    number: '٣',
    title: 'سجّل التحصيل',
    desc: 'سدّد الدفعة من داخل المتابعة نفسها، ويتحدّث جدول الاستحقاقات والتقارير تلقائياً.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  },
];
---

<section class="py-20 md:py-28 bg-[#0f1729] border-y border-[#1f2937]">
  <div class="container">

    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        يومك في قيد العقار
      </h2>
      <p class="text-text-muted text-lg max-w-xl mx-auto">
        حلقة يومية واحدة تربط ما يحتاج انتباهك بما تم إنجازه فعلاً.
      </p>
    </div>

    <!-- Steps -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative">

      <!-- Connector line (desktop) -->
      <div class="hidden md:block absolute top-14 right-[calc(16.67%+24px)] left-[calc(16.67%+24px)] h-px bg-gradient-to-l from-transparent via-brand-primary/30 to-transparent" aria-hidden="true"></div>

      {steps.map((step) => (
        <div class="relative text-center">
          <!-- Number circle -->
          <div class="w-16 h-16 rounded-full bg-brand-primary/10 border-2 border-brand-primary/30 flex items-center justify-center mx-auto mb-6 relative z-10">
            <span class="text-2xl font-bold text-brand-primary">{step.number}</span>
          </div>
          <div class="text-brand-primary mb-4 flex justify-center">
            <Fragment set:html={step.icon} />
          </div>
          <h3 class="text-white font-semibold text-xl mb-3">{step.title}</h3>
          <p class="text-text-muted text-sm leading-relaxed max-w-xs mx-auto">{step.desc}</p>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-14">
      <a
        href={requestAccessMailto}
        class="inline-block px-8 py-4 bg-brand-primary hover:bg-brand-dark text-[#0F172D] font-semibold rounded-xl text-base transition-all hover:shadow-lg hover:shadow-brand-primary/25 hover:-translate-y-0.5"
      >
        اطلب انضمامك
      </a>
    </div>

  </div>
</section>
