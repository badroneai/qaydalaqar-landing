---
const steps = [
  {
    number: '١',
    title: 'سجّل حسابك',
    desc: 'دقيقة واحدة بالبريد الإلكتروني، وأنت جاهز. لا بيانات بطاقة، لا عقود.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>`,
  },
  {
    number: '٢',
    title: 'أدخل حركاتك',
    desc: 'دخل أو مصروف أو عمولة — خياراتك جاهزة، الواجهة بديهية، لا تدريب مطلوب.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>`,
  },
  {
    number: '٣',
    title: 'اطّلع على نتائجك',
    desc: 'لوحة تحكم تعرض وضعك المالي فوراً — دخل، مصروفات، عمولات، صافي ربح.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
  },
];
---

<section class="py-20 md:py-28 bg-[#0f1729] border-y border-[#1f2937]">
  <div class="container">

    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        ثلاث خطوات وانتهيت
      </h2>
      <p class="text-text-muted text-lg max-w-xl mx-auto">
        ما من تعقيد ولا دورات تدريبية. تبدأ وتنتج من اليوم الأول.
      </p>
    </div>

    <!-- Steps -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative">

      <!-- Connector line (desktop) -->
      <div class="hidden md:block absolute top-14 right-[calc(16.67%+24px)] left-[calc(16.67%+24px)] h-px bg-gradient-to-l from-transparent via-brand-primary/30 to-transparent" aria-hidden="true"></div>

      {steps.map((step, i) => (
        <div class="relative text-center">
          <!-- Number circle -->
          <div class="w-16 h-16 rounded-full bg-brand-primary/10 border-2 border-brand-primary/30 flex items-center justify-center mx-auto mb-6 relative z-10">
            <span class="text-2xl font-bold text-brand-primary">{step.number}</span>
          </div>
          <div class="text-brand-primary mb-4 flex justify-center">
            <Fragment set:html={step.icon} />
          </div>
          <h3 class="text-white font-semibold text-xl mb-3">{step.title}</h3>
          <p class="text-text-muted text-sm leading-relaxed max-w-xs mx-auto">{step.desc}</p>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-14">
      <a
        href="https://app.qaydalaqar.com/auth/signup"
        class="inline-block px-8 py-4 bg-brand-primary hover:bg-brand-dark text-white font-semibold rounded-xl text-base transition-all hover:shadow-lg hover:shadow-brand-primary/25 hover:-translate-y-0.5"
      >
        ابدأ الآن مجاناً
      </a>
    </div>

  </div>
</section>
