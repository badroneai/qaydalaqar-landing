---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description: string;
  pubDate: string;
  author?: string;
  image?: string;
  tags?: string[];
  slug: string;
}

const { title, description, pubDate, author = 'فريق قيد العقار', image = '/og-image.png', tags = [], slug } = Astro.props;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  author: { '@type': 'Person', name: author },
  publisher: {
    '@type': 'Organization',
    name: 'قيد العقار',
    logo: { '@type': 'ImageObject', url: 'https://qaydalaqar.com/favicon.svg' },
  },
  datePublished: pubDate,
  dateModified: pubDate,
  image: image.startsWith('http') ? image : `https://qaydalaqar.com${image}`,
  url: `https://qaydalaqar.com/blog/${slug}`,
};

const formattedDate = new Date(pubDate).toLocaleDateString('ar-SA', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={`${title} | مدونة قيد العقار`}
  description={description}
  canonical={`/blog/${slug}`}
  ogImage={image}
  type="article"
  articleDate={pubDate}
  jsonLd={articleSchema}
>
  <article class="py-20 md:py-28">
    <div class="container max-w-3xl">
      <!-- Breadcrumb -->
      <nav class="mb-8 text-sm text-text-muted" aria-label="breadcrumb">
        <a href="/" class="hover:text-brand-primary transition-colors">الرئيسية</a>
        <span class="mx-2">/</span>
        <a href="/blog" class="hover:text-brand-primary transition-colors">المدونة</a>
        <span class="mx-2">/</span>
        <span class="text-gray-300">{title}</span>
      </nav>

      <!-- Tags -->
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-6">
          {tags.map((tag) => (
            <span class="px-3 py-1 bg-brand-primary/10 text-brand-primary rounded-full text-xs font-medium border border-brand-primary/20">
              {tag}
            </span>
          ))}
        </div>
      )}

      <!-- Title -->
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-6 leading-tight">{title}</h1>

      <!-- Meta -->
      <div class="flex items-center gap-4 text-text-muted text-sm mb-10 pb-8 border-b border-border">
        <span>بقلم {author}</span>
        <span>·</span>
        <time datetime={pubDate}>{formattedDate}</time>
      </div>

      <!-- Content -->
      <div class="prose prose-invert prose-lg max-w-none
        prose-headings:font-bold prose-headings:text-white
        prose-p:text-gray-300 prose-p:leading-relaxed
        prose-a:text-brand-primary prose-a:no-underline hover:prose-a:underline
        prose-strong:text-white prose-strong:font-semibold
        prose-li:text-gray-300
        prose-code:text-brand-primary prose-code:bg-bg-muted prose-code:px-1 prose-code:rounded
        prose-blockquote:border-r-4 prose-blockquote:border-brand-primary prose-blockquote:border-l-0 prose-blockquote:pr-4 prose-blockquote:pl-0
      ">
        <slot />
      </div>

      <!-- CTA -->
      <div class="mt-16 p-8 bg-bg-soft rounded-2xl border border-border text-center">
        <h3 class="text-xl font-bold text-white mb-3">جرّب قيد العقار مجاناً</h3>
        <p class="text-text-muted mb-6">ابدأ إدارة مكتبك العقاري بشكل احترافي اليوم — بدون بطاقة ائتمان.</p>
        <a
          href="https://app.qaydalaqar.com/auth/signup"
          class="inline-block px-8 py-3 bg-brand-primary hover:bg-brand-dark text-white font-semibold rounded-xl transition-colors"
        >
          أنشئ حسابك الآن
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
