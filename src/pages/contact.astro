---
import BaseLayout from '../layouts/BaseLayout.astro';

const contactEmailUrl = `mailto:info@qaydalaqar.com?subject=${encodeURIComponent('تواصل حول قيد العقار')}&body=${encodeURIComponent('اسم المكتب:\nالمدينة:\nعدد عقود الإيجار النشطة تقريباً:\nسؤالك أو ملاحظتك:')}`;
---

<BaseLayout
  title="تواصل معنا | قيد العقار"
  description="تواصل مع قيد العقار بسؤال أو ملاحظة حول النسخة التجريبية الحالية."
  canonical="/contact"
>

  <section class="py-20 md:py-28">
    <div class="container max-w-2xl">

      <div class="text-center mb-14">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">تواصل معنا</h1>
        <p class="text-text-muted text-lg">
          التسجيل التجريبي متاح مباشرة. وإذا أردت مشاركة طريقة عمل مكتبك أو سؤالنا عن النسخة الحالية، راسلنا.
        </p>
      </div>

      <!-- Contact cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
        <a
          href={contactEmailUrl}
          class="card-hover p-6 rounded-2xl bg-[#0f1729] border border-[#1f2937] text-center block"
        >
          <div class="w-12 h-12 rounded-xl bg-brand-primary/10 flex items-center justify-center text-brand-primary mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="text-white font-semibold mb-2">راسلنا</h3>
          <p class="text-brand-primary text-sm">يفتح رسالة مجهزة بالمعلومات الأساسية</p>
        </a>

        <div class="p-6 rounded-2xl bg-[#0f1729] border border-[#1f2937] text-center">
          <div class="w-12 h-12 rounded-xl bg-brand-primary/10 flex items-center justify-center text-brand-primary mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="text-white font-semibold mb-2">ما الذي نحتاجه؟</h3>
          <p class="text-text-muted text-sm">المدينة، عدد العقود، وطريقة المتابعة الحالية</p>
        </div>
      </div>

      <!-- Note -->
      <div class="p-6 rounded-2xl bg-[#0f1729] border border-brand-primary/20 text-center">
        <p class="text-text-muted text-sm leading-relaxed">
          النسخة الحالية موجهة أولاً للمكاتب التي تدير عقود إيجار وتحتاج متابعة الاستحقاقات والمتأخرات من سجل واحد.
        </p>
        <a
          href={contactEmailUrl}
          class="inline-block mt-6 px-6 py-3 bg-brand-primary hover:bg-brand-dark text-[#0F172D] font-semibold rounded-xl transition-colors"
        >
          جهّز رسالتك
        </a>
      </div>

    </div>
  </section>

</BaseLayout>
