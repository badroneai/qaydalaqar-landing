---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  articleJsonLd,
  articleUrl,
  publicResourceArticles,
  type PublicResourceArticle,
} from '../../content/resources';
import { findResourceTopic, topicUrl, type ResourceTopic } from '../../content/resource-topics';
import {
  findResourceTemplate,
  templateUrl,
  type ResourceTemplate,
} from '../../content/resource-templates';

export function getStaticPaths() {
  return publicResourceArticles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

interface Props {
  article: PublicResourceArticle;
}

const { article } = Astro.props;
const related = article.relatedSlugs?.length
  ? article.relatedSlugs
      .map((slug) => publicResourceArticles.find((candidate) => candidate.slug === slug))
      .filter((candidate): candidate is PublicResourceArticle => Boolean(candidate))
  : publicResourceArticles.filter((candidate) => candidate.slug !== article.slug).slice(0, 3);
const relatedTopics = article.relatedTopicSlugs
  ?.map((slug) => findResourceTopic(slug))
  .filter((topic): topic is ResourceTopic => Boolean(topic)) ?? [];
const relatedTemplates = article.relatedTemplateSlugs
  ?.map((slug) => findResourceTemplate(slug))
  .filter((template): template is ResourceTemplate => Boolean(template)) ?? [];
---

<BaseLayout
  title={`${article.title} | قيد العقار`}
  description={article.description}
  canonical={articleUrl(article)}
  type="article"
  articleDate={article.updatedAt}
  jsonLd={articleJsonLd(article)}
>
  <article>
    <header class="relative py-20 md:py-28 overflow-hidden border-b border-[#1f2937]">
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-brand-primary/30 to-transparent"></div>
        <div class="absolute -top-40 -right-40 w-96 h-96 bg-brand-primary/5 rounded-full blur-3xl"></div>
      </div>
      <div class="container relative max-w-4xl">
        <a href="/resources" class="text-brand-primary text-sm font-semibold hover:underline">مركز المعرفة</a>
        <div class="flex flex-wrap items-center gap-3 mt-6 mb-5">
          <span class="px-3 py-1 bg-brand-primary/10 text-brand-primary text-xs rounded-full border border-brand-primary/20 font-semibold">
            {article.category}
          </span>
          <span class="text-text-muted text-xs">{article.readingTime}</span>
          <time datetime={article.updatedAt} class="text-text-muted text-xs">آخر تحديث: {article.updatedAt}</time>
        </div>
        <h1 class="text-4xl md:text-6xl font-bold text-white leading-tight mb-6">{article.title}</h1>
        <p class="text-text-muted text-lg md:text-xl leading-relaxed">{article.description}</p>
        <p class="text-text-muted text-sm mt-5">الجمهور المناسب: {article.audience}</p>
      </div>
    </header>

    <div class="container max-w-4xl py-14 md:py-20">
      <div class="space-y-12">
        {article.sections.map((section) => (
          <section>
            <h2 class="text-2xl md:text-3xl font-bold text-white mb-5">{section.heading}</h2>
            <div class="space-y-5">
              {section.body.map((paragraph) => (
                <p class="text-gray-300 leading-9 text-lg">{paragraph}</p>
              ))}
            </div>
          </section>
        ))}
      </div>

      <aside class="mt-12 rounded-2xl border border-brand-primary/30 bg-brand-primary/10 p-6 md:p-8">
        <h2 class="text-white font-bold text-xl mb-3">الخلاصة العملية</h2>
        <p class="text-gray-200 leading-relaxed">{article.takeaway}</p>
      </aside>

      {relatedTopics.length > 0 && (
        <section class="mt-16">
          <h2 class="text-2xl font-bold text-white mb-6">مسارات تقرأ بعدها</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
            {relatedTopics.map((topic) => (
              <article class="card-hover rounded-2xl bg-[#0f1729] border border-[#1f2937] p-5">
                <p class="text-brand-primary text-xs font-semibold mb-3">{topic.eyebrow}</p>
                <h3 class="text-white font-semibold leading-snug">
                  <a href={topicUrl(topic)} class="hover:text-brand-primary transition-colors">
                    {topic.title}
                  </a>
                </h3>
                <p class="mt-3 text-text-muted text-sm leading-relaxed">{topic.description}</p>
              </article>
            ))}
          </div>
        </section>
      )}

      {relatedTemplates.length > 0 && (
        <section class="mt-16">
          <h2 class="text-2xl font-bold text-white mb-6">قوالب تساعدك على التطبيق</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            {relatedTemplates.map((template) => (
              <article class="card-hover rounded-2xl bg-[#0f1729] border border-[#1f2937] p-5">
                <p class="text-brand-primary text-xs font-semibold mb-3">{template.category}</p>
                <h3 class="text-white font-semibold leading-snug">
                  <a href={templateUrl(template)} class="hover:text-brand-primary transition-colors">
                    {template.title}
                  </a>
                </h3>
                <p class="mt-3 text-text-muted text-sm leading-relaxed">{template.description}</p>
              </article>
            ))}
          </div>
        </section>
      )}

      <section class="mt-16">
        <h2 class="text-2xl font-bold text-white mb-6">أدلة مرتبطة</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          {related.map((item) => (
            <article class="card-hover rounded-2xl bg-[#0f1729] border border-[#1f2937] p-5">
              <p class="text-brand-primary text-xs font-semibold mb-3">{item.category}</p>
              <h3 class="text-white font-semibold leading-snug">
                <a href={articleUrl(item)} class="hover:text-brand-primary transition-colors">
                  {item.title}
                </a>
              </h3>
            </article>
          ))}
        </div>
      </section>
    </div>
  </article>
</BaseLayout>
