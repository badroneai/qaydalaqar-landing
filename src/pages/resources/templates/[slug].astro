---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { articleUrl, publicResourceArticles, PUBLIC_SITE_NAME } from '../../../content/resources';
import { findResourceTopic, topicUrl } from '../../../content/resource-topics';
import {
  publicResourceTemplates,
  templateJsonLd,
  templateUrl,
  type ResourceTemplate,
} from '../../../content/resource-templates';

export function getStaticPaths() {
  return publicResourceTemplates.map((template) => ({
    params: { slug: template.slug },
    props: { template },
  }));
}

const { template } = Astro.props as { template: ResourceTemplate };
const topic = findResourceTopic(template.relatedTopicSlug);
const relatedArticles = publicResourceArticles.filter((article) =>
  template.relatedArticleSlugs.includes(article.slug),
);
const title = `${template.title} | ${PUBLIC_SITE_NAME}`;
const canonical = templateUrl(template);
---

<BaseLayout
  title={title}
  description={template.description}
  canonical={canonical}
  jsonLd={templateJsonLd(template)}
>
  <section class="relative py-20 md:py-28 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-brand-primary/30 to-transparent"></div>
      <div class="absolute -top-40 -left-40 w-96 h-96 bg-brand-primary/5 rounded-full blur-3xl"></div>
    </div>

    <div class="container relative">
      <div class="max-w-4xl">
        <a href="/resources/templates" class="text-brand-primary font-semibold hover:underline">القوالب العملية</a>
        <div class="mt-6 flex flex-wrap items-center gap-3">
          <span class="px-3 py-1 bg-brand-primary/10 text-brand-primary text-xs rounded-full border border-brand-primary/20 font-semibold">
            {template.category}
          </span>
          <span class="text-text-muted text-sm">{template.readingTime}</span>
        </div>
        <h1 class="mt-4 text-4xl md:text-6xl font-bold text-white leading-tight">
          {template.title}
        </h1>
        <p class="mt-6 text-text-muted text-lg md:text-xl leading-relaxed">
          {template.description}
        </p>
      </div>
    </div>
  </section>

  <section class="pb-20 md:pb-28">
    <div class="container">
      <div class="grid lg:grid-cols-[minmax(0,1.15fr)_minmax(320px,0.85fr)] gap-8 items-start">
        <article class="rounded-2xl bg-[#0f1729] border border-[#1f2937] p-6 md:p-8">
          <p class="text-brand-primary text-sm font-semibold mb-3">طريقة الاستخدام</p>
          <p class="text-gray-300 leading-relaxed text-lg">
            {template.summary}
          </p>

          <div class="mt-10">
            <h2 class="text-white text-2xl font-bold mb-5">متى تستخدم هذا القالب؟</h2>
            <ul class="space-y-3">
              {template.useWhen.map((item) => (
                <li class="flex gap-3 rounded-xl bg-background/60 border border-[#1f2937] p-4 text-gray-300 leading-relaxed">
                  <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-brand-primary"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="mt-10 space-y-6">
            <h2 class="text-white text-2xl font-bold">نص القالب</h2>
            {template.blocks.map((block) => (
              <section class="rounded-xl border border-[#273449] bg-background/50 p-5">
                <h3 class="text-white text-xl font-bold mb-3">{block.heading}</h3>
                {block.intro && <p class="text-text-muted leading-relaxed mb-4">{block.intro}</p>}
                <ul class="space-y-3">
                  {block.rows.map((row) => (
                    <li class="rounded-lg border border-[#1f2937] bg-[#0f1729] px-4 py-3 text-gray-200 leading-relaxed">
                      {row}
                    </li>
                  ))}
                </ul>
              </section>
            ))}
          </div>

          <div class="mt-10 rounded-xl border border-amber-400/20 bg-amber-400/10 p-5">
            <h2 class="text-white text-xl font-bold mb-4">تنبيهات قبل الاعتماد</h2>
            <ul class="space-y-3">
              {template.cautions.map((item) => (
                <li class="text-gray-300 leading-relaxed">• {item}</li>
              ))}
            </ul>
          </div>
        </article>

        <aside class="space-y-6">
          {topic && (
            <section class="rounded-2xl bg-[#0f1729] border border-[#1f2937] p-6">
              <p class="text-brand-primary text-sm font-semibold mb-2">المسار المرتبط</p>
              <h2 class="text-white text-xl font-bold mb-3">{topic.title}</h2>
              <p class="text-text-muted text-sm leading-relaxed mb-5">{topic.description}</p>
              <a href={topicUrl(topic)} class="text-brand-primary text-sm font-semibold hover:underline">
                فتح المسار ←
              </a>
            </section>
          )}

          <section class="rounded-2xl bg-[#0f1729] border border-[#1f2937] p-6">
            <h2 class="text-white text-xl font-bold mb-4">أدلة تساعدك</h2>
            <div class="space-y-4">
              {relatedArticles.map((article) => (
                <a
                  href={articleUrl(article)}
                  class="block rounded-xl border border-[#273449] bg-background/50 p-4 hover:border-brand-primary/50 transition-colors"
                >
                  <p class="text-brand-primary text-xs font-semibold mb-2">{article.category}</p>
                  <h3 class="text-white font-bold leading-snug">{article.title}</h3>
                  <p class="mt-2 text-text-muted text-sm leading-relaxed">{article.description}</p>
                </a>
              ))}
            </div>
          </section>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
