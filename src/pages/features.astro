---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBanner from '../components/CtaBanner.astro';

const features = [
  {
    id: 'radar',
    title: 'الرادار والمتابعات',
    subtitle: 'يومك يبدأ بقائمة انتباه واحدة',
    desc: 'الرادار يعرض ما يحتاج انتباهك اليوم مرتباً حسب الأولوية، ويمكن تحويل الدفعة المتأخرة منه إلى متابعة لها مسؤول وحالة وسجل نشاط.',
    details: [
      'دفعات متأخرة وعقود تقترب من الانتهاء وفجوات تشغيلية في شاشة واحدة',
      'إنشاء متابعة من إشارة الدفعة المتأخرة بدون إعادة إدخال',
      'سجل نشاط كامل لكل متابعة: من استلمها، ماذا حدث، وكيف أُغلقت',
      'أرشيف للمتابعات المغلقة للرجوع إليه في أي وقت',
    ],
  },
  {
    id: 'leases',
    title: 'عقود الإيجار والاستحقاقات',
    subtitle: 'كل عقد بجدول استحقاق واضح',
    desc: 'أنشئ العقد وسيتولد جدول استحقاقاته، أو ارفع ملف عقد من منصة إيجار (PDF) وراجع بياناته قبل الإنشاء.',
    details: [
      'استيراد ملف عقد إيجار (PDF) بمراجعة منك قبل إنشاء أي سجل',
      'جدول استحقاقات يتولد تلقائياً ويبقى مربوطاً بملف المصدر',
      'مستند عقد جاهز للطباعة',
      'تفاصيل العقد كما هي مسجلة في منصة إيجار محفوظة على العقد للمرجعية',
    ],
  },
  {
    id: 'collection',
    title: 'التحصيل',
    subtitle: 'نسبة تحصيل تراها ولا تخمّنها',
    desc: 'الدفعات مربوطة بالاستحقاقات، وتستطيع تسجيل السداد من داخل المتابعة نفسها فيتحدث الجدول والتقارير تلقائياً.',
    details: [
      'تسجيل دفعات مربوطة بجدول الاستحقاقات',
      'تسجيل السداد من داخل المتابعة المرتبطة بالدفعة المتأخرة',
      'حالة كل استحقاق واضحة: مسدد، جزئي، متأخر',
      'تقرير نسبة التحصيل وأعمار الديون',
    ],
  },
  {
    id: 'office-ledger',
    title: 'دفتر المكتب',
    subtitle: 'حسابات المكتب منفصلة عن حسابات العقارات',
    desc: 'مصروفات المكتب والتزاماته الدورية (إيجار المقر، الاشتراكات، الرواتب وغيرها) في دفتر مستقل بتصنيفاته وتقاريره.',
    details: [
      'معاملات المكتب بتصنيفات قابلة للتخصيص',
      'التزامات دورية بمواعيد استحقاق وتسوية',
      'فصل كامل بين أرقام المكتب وأرقام العقارات',
      'تقارير خاصة بدفتر المكتب',
    ],
  },
  {
    id: 'reports',
    title: 'التقارير',
    subtitle: 'أرقام المكتب أمامك لا في ذاكرة أحد',
    desc: 'تقارير مبنية من بيانات التشغيل نفسها: التدفق النقدي، نسبة التحصيل، أعمار الديون، وملخص لكل عقار.',
    details: [
      'تقرير التدفق النقدي',
      'تقرير نسبة التحصيل',
      'تقرير أعمار الديون (المتأخرات حسب مدة التأخر)',
      'ملخص لكل عقار: وحداته وعقوده ودفعاته',
    ],
  },
  {
    id: 'documents-memory',
    title: 'المستندات والذاكرة',
    subtitle: 'معرفة المكتب تبقى في المكتب',
    desc: 'ملف مصدر يبقى مرتبطاً بالعقد المستورد، وخطابات رسمية تُنشأ من داخل النظام، وذاكرة مكتب تحفظ الملاحظات المهمة.',
    details: [
      'ملف عقد المصدر محفوظ ومرتبط بالعقد الذي أُنشئ منه',
      'إنشاء خطابات رسمية من داخل النظام',
      'ملاحظات على السجلات بصلاحيات واضحة',
      'ذاكرة مكتب للملاحظات والقرارات المهمة',
    ],
  },
];
---

<BaseLayout
  title="مميزات قيد العقار | وحدات المكتب في مكان واحد"
  description="تعرف على وحدات قيد العقار: الرادار والمتابعات، عقود الإيجار والاستحقاقات، التحصيل، دفتر المكتب، التقارير، والمستندات والذاكرة."
  canonical="/features"
>

  <!-- Hero -->
  <section class="py-20 md:py-28 text-center">
    <div class="container max-w-2xl">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">
        وحدات المكتب في
        <span class="gradient-text"> مكان واحد</span>
      </h1>
      <p class="text-text-muted text-lg">
        مبني حول يوم المكتب العقاري السعودي الفعلي: من رادار الصباح إلى تحصيل آخر دفعة.
      </p>
    </div>
  </section>

  <!-- Features detail -->
  <section class="pb-20 md:pb-28">
    <div class="container max-w-4xl space-y-8">
      {features.map((feature) => (
        <div id={feature.id} class="p-8 rounded-2xl bg-[#0f1729] border border-[#1f2937]">
          <p class="text-brand-accent text-sm font-semibold mb-2">{feature.subtitle}</p>
          <h2 class="text-white font-bold text-2xl mb-4">{feature.title}</h2>
          <p class="text-text-muted leading-relaxed mb-6">{feature.desc}</p>
          <ul class="grid grid-cols-1 md:grid-cols-2 gap-3">
            {feature.details.map((detail) => (
              <li class="flex items-start gap-3 text-sm text-gray-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#C5CCD9" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0 mt-0.5">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                {detail}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <CtaBanner />

</BaseLayout>
