---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Faq from '../components/Faq.tsx';

const signupUrl = 'https://app.qaydalaqar.com/auth/signup';
---

<BaseLayout
  title="ابدأ مع قيد العقار | إطلاق تجريبي"
  description="قيد العقار في مرحلة إطلاق تجريبي — أنشئ حساب مكتبك بالبريد الإلكتروني وابدأ مباشرة. الأسعار تُعلن لاحقاً ويُبلَّغ المستخدمون الحاليون بها أولاً."
  canonical="/pricing"
>

  <!-- Hero -->
  <section class="py-20 md:py-28 text-center">
    <div class="container max-w-2xl">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">
        ابدأ مع
        <span class="gradient-text"> قيد العقار</span>
      </h1>
      <p class="text-text-muted text-lg">
        قيد العقار في مرحلة إطلاق تجريبي — أنشئ حساب مكتبك بالبريد الإلكتروني وابدأ الاستخدام فوراً.
      </p>
    </div>
  </section>

  <!-- Getting started -->
  <section class="pb-20 md:pb-28">
    <div class="container">
      <div class="max-w-2xl mx-auto p-8 md:p-10 rounded-2xl bg-[#0f1729] border border-brand-primary/30">
        <h2 class="text-white font-bold text-xl mb-6 text-center">ماذا تعني مرحلة الإطلاق التجريبي؟</h2>
        <ul class="space-y-4 text-sm text-gray-300 mb-10">
          {[
            'التسجيل مباشر بالبريد الإلكتروني — بلا موافقات ولا انتظار.',
            'تبدأ فوراً على عمل مكتبك الحقيقي: عقارات وعقود وتحصيل ومصروفات.',
            'الاستخدام خلال هذه المرحلة متاح بلا رسوم.',
            'الأسعار تُعلن لاحقاً — المستخدمون الحاليون يُبلَّغون بها أولاً قبل أي التزام.',
            'ملاحظاتك تشكّل المنتج مباشرة: راسلنا على info@qaydalaqar.com بأي ملاحظة.',
          ].map((item) => (
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#C5CCD9" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0 mt-0.5">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              {item}
            </li>
          ))}
        </ul>
        <div class="text-center">
          <a
            href={signupUrl}
            class="inline-block px-10 py-4 bg-brand-primary hover:bg-brand-dark text-[#0F172D] font-bold rounded-xl transition-all hover:shadow-lg hover:shadow-brand-primary/20 hover:-translate-y-0.5"
          >
            أنشئ حساب مكتبك
          </a>
          <p class="text-text-muted text-sm mt-6">
            لديك حساب؟
            <a href="https://app.qaydalaqar.com/auth/login" class="text-brand-primary hover:underline">تسجيل الدخول</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="pb-20 md:pb-28">
    <div class="container">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">أسئلة شائعة</h2>
      </div>
      <div class="max-w-3xl mx-auto">
        <Faq client:load />
      </div>
    </div>
  </section>

  <CtaBanner />

</BaseLayout>
