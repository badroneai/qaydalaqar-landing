---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBanner from '../components/CtaBanner.astro';
---

<BaseLayout
  title="من نحن | قيد العقار"
  description="قصة قيد العقار — كيف بدأت، لماذا بُني، ومن يقف خلفه. نظام مالي عربي للمكاتب العقارية."
  canonical="/about"
>

  <!-- Hero -->
  <section class="py-20 md:py-28">
    <div class="container max-w-3xl">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-8 leading-tight">
        لماذا قيد العقار؟
      </h1>

      <div class="space-y-6 text-gray-300 leading-relaxed text-lg">
        <p>
          كل صاحب مكتب عقاري يعرف المشكلة: الأرقام متفرقة بين نوتة، جداول Excel، وتطبيقات دردشة. العمولات تُنسى أو تتأخر. توزيع الوكلاء يعتمد على الثقة لا على السجل. وفي نهاية الشهر، لا أحد يعرف الرقم الحقيقي.
        </p>
        <p>
          <strong class="text-white">قيد العقار</strong> بُني لحل هذه المشكلة تحديداً. ليس نظاماً محاسبياً معقداً، ولا جداول بيانات تحتاج دورة تدريبية. هو نظام مالي بسيط، عربي، مصمَّم بمعرفة عميقة بطريقة عمل المكاتب العقارية السعودية فعلاً.
        </p>
        <p>
          بدأ المشروع من ملاحظة بسيطة: أصحاب المكاتب العقارية يقضون وقتاً كبيراً في تتبع الأرقام يدوياً، بينما هذا الوقت يجب أن يُصرف في بناء الأعمال. الحل ليس برنامجاً ضخماً، بل أداة مركّزة تفعل ما يحتاجه المكتب فعلاً — لا أكثر، لا أقل.
        </p>
      </div>

      <!-- Values -->
      <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            title: 'البساطة',
            desc: 'ما من تعقيد غير ضروري. كل شيء في مكانه الصحيح.',
          },
          {
            title: 'الوضوح',
            desc: 'أرقامك يجب أن تكون واضحة لك في أي لحظة.',
          },
          {
            title: 'الثقة',
            desc: 'بياناتك آمنة ومعزولة. ما نشاركها مع أحد.',
          },
        ].map((v) => (
          <div class="p-6 rounded-2xl bg-[#0f1729] border border-[#1f2937]">
            <div class="w-8 h-8 rounded-lg bg-brand-primary/10 flex items-center justify-center text-brand-primary mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </div>
            <h3 class="text-white font-bold mb-2">{v.title}</h3>
            <p class="text-text-muted text-sm">{v.desc}</p>
          </div>
        ))}
      </div>

      <!-- Contact -->
      <div class="mt-14 p-8 rounded-2xl bg-[#0f1729] border border-[#1f2937] text-center">
        <h2 class="text-xl font-bold text-white mb-3">تواصل معنا</h2>
        <p class="text-text-muted mb-6">
          أسئلة، ملاحظات، أو اقتراحات لتحسين النظام؟ نسمعك.
        </p>
        <a
          href="/contact"
          class="inline-block px-6 py-3 bg-brand-primary hover:bg-brand-dark text-white font-semibold rounded-xl transition-colors"
        >
          تواصل معنا
        </a>
      </div>
    </div>
  </section>

  <CtaBanner />

</BaseLayout>
